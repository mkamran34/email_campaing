# Nginx Configuration for Production Email System Deployment
# Location: /etc/nginx/sites-available/email-system
#
# Setup:
#   1. Copy this file to /etc/nginx/sites-available/email-system
#   2. Replace 'yourdomain.com' with your actual domain
#   3. Generate SSL certificate: certbot certonly --nginx -d yourdomain.com
#   4. Create symlink: ln -s /etc/nginx/sites-available/email-system /etc/nginx/sites-enabled/
#   5. Test: nginx -t
#   6. Restart: systemctl restart nginx

# Redirect HTTP to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name yourdomain.com www.yourdomain.com;
    return 301 https://$server_name$request_uri;
}

# HTTPS/SSL Configuration
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name yourdomain.com www.yourdomain.com;

    # SSL Configuration
    ssl_certificate /etc/letsencrypt/live/yourdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/yourdomain.com/privkey.pem;

    # Modern SSL Configuration
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_stapling on;
    ssl_stapling_verify on;

    # Security Headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;

    # Logging
    access_log /var/log/nginx/email-system-access.log combined buffer=32k flush=5s;
    error_log /var/log/nginx/email-system-error.log warn;

    # Increase client body size for file uploads
    client_max_body_size 10M;
    client_body_timeout 10s;
    client_header_timeout 10s;

    # Timeouts
    keepalive_timeout 65;
    send_timeout 10s;

    # Gzip Compression
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/javascript text/xml application/xml application/rss+xml;
    gzip_min_length 1000;
    gzip_vary on;
    gzip_comp_level 6;

    # Upstream server (Gunicorn application)
    upstream email_system {
        server 127.0.0.1:5001 fail_timeout=0;
    }

    # Static files with caching
    location /static/ {
        alias /var/www/email-system/static/;
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Logs directory
    location /logs/ {
        deny all;
    }

    # Hide sensitive files
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    location ~ ~$ {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Main application
    location / {
        proxy_pass http://email_system;
        proxy_http_version 1.1;

        # Headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
        proxy_set_header Connection "";

        # Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        # Buffering
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;
    }

    # Health check endpoint (optional)
    location /health {
        access_log off;
        proxy_pass http://email_system;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
    }

    # Status page (optional, restrict to admin IP)
    location /nginx-status {
        stub_status;
        access_log off;
        allow 127.0.0.1;
        deny all;
    }
}

# Rate limiting (optional)
# Define outside server block:
# limit_req_zone $binary_remote_addr zone=api_limit:10m rate=10r/s;
# Add in location block:
# limit_req zone=api_limit burst=20 nodelay;
